model User {
    id       String  @id @default(uuid())
    name     String  @db.VarChar(255)
    email    String  @unique 
    password String  
    activeStatus ActiveStatus @default(ACTIVE)
    role     Role  @default(USER)
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
    profile profile?
    comments Comment[]
    posts Post[]
    @@map("users")
}

